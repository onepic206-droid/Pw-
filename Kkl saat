-- ================= WEBHOOK =================
local function sendWebhook(botId)

    if WEBHOOK_URL == "" then
        return
    end

    local hours =
        math.floor(UPTIME_SECONDS / 3600)

    local minutes =
        math.floor(
            (UPTIME_SECONDS % 3600) / 60
        )

    local seconds =
        UPTIME_SECONDS % 60

    local uptimeText = string.format(
        "%02d:%02d:%02d",
        hours,
        minutes,
        seconds
    )

    local embed = {

        title = "AUTO WATER BREAK",
        description =
            "Realtime Zenith Statistics",

        color = 5763719,

        fields = {

            {
                name = "BOT",
                value = string.format(
                    "Bot ID : %s\nStatus : ONLINE",
                    tostring(botId)
                ),
                inline = false
            },

            {
                name = "FARM",
                value = string.format(
                    "Total Broken : %d\nWorlds Done : %d",
                    TOTAL_BROKEN,
                    TOTAL_WORLDS
                ),
                inline = false
            },

            {
                name = "UPTIME",
                value = uptimeText,
                inline = false
            }

        }
    }

    pcall(function()

        webhook(WEBHOOK_URL, {

            username = "Zenith Water Bot",

            embeds = { embed }

        })

    end)
end


local function updateWebhook(botId, elapsedMs)

    WEBHOOK_ELAPSED =
        WEBHOOK_ELAPSED + elapsedMs

    UPTIME_SECONDS =
        UPTIME_SECONDS +
        math.floor(elapsedMs / 1000)

    if WEBHOOK_ELAPSED >= WEBHOOK_INTERVAL then

        sendWebhook(botId)

        WEBHOOK_ELAPSED = 0
    end
end
