-- ================= UTILS =================
local function log(id, txt)
    print("[Bot " .. id .. "] " .. txt)
end

local function rnd(min, max)
    return math.random(min, max)
end

local function rsleep(ms)
    sleep(ms + rnd(CONFIG.RAND_MIN, CONFIG.RAND_MAX))
end

local function generateWorldName()

    local result = ""

    for i = 1, 7 do
        result = result .. string.char(
            math.random(65, 90)
        )
    end

    return result
end

local function getDropLocation()

    local randomX = math.random(
        CONFIG.DROP_X_MIN,
        CONFIG.DROP_X_MAX
    )

    return Vector2i.new(
        randomX,
        CONFIG.DROP_Y
    )
end
