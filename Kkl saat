-- ================= CONFIG =================
local CONFIG = {

    SAVE_WORLD        = "WORLD:AB",

    DROP_Y            = 12,

    DROP_X_MIN        = 1,
    DROP_X_MAX        = 20,

    WATER_BLOCK_ID    = 18,

    DROP_THRESHOLD    = 50,

    HIT_DELAY         = 300,
    MAX_HITS          = 25,

    TILE_DELAY        = 120,
    COLLECT_DELAY     = 50,

    RECONNECT_DELAY   = 5000,
    PATH_TIMEOUT      = 10000,

    RAND_MIN          = 30,
    RAND_MAX          = 150,
}
-- ==========================================


-- ================= WEBHOOK =================
local WEBHOOK_URL      = "https://discord.com/api/webhooks/1479853594416124016/Da1c-O02WM5AenCTT5GaKihq6oevBXvhjN4Br_lWQhkO_ESm8BcGMNTIf3bxIiVZW6_P"
local WEBHOOK_INTERVAL = 60000

local WEBHOOK_ELAPSED  = 0
local UPTIME_SECONDS   = 0

local TOTAL_BROKEN     = 0
local TOTAL_WORLDS     = 0
-- ===========================================


-- ================= AUTO COLLECT =================
getPreferences().collect = true
getPreferences().collectInterval = 50
